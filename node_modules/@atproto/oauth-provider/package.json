{
  "name": "@atproto/oauth-provider",
  "version": "0.6.6",
  "license": "MIT",
  "description": "Generic OAuth2 and OpenID Connect provider for Node.js. Currently only supports features needed for Atproto.",
  "keywords": [
    "atproto",
    "oauth",
    "oauth2",
    "open id connect",
    "oidc",
    "provider",
    "oidc provider"
  ],
  "homepage": "https://atproto.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesky-social/atproto",
    "directory": "packages/oauth/oauth-provider"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.7.0"
  },
  "dependencies": {
    "@hapi/accept": "^6.0.3",
    "@hapi/address": "^5.1.1",
    "@hapi/bourne": "^3.0.0",
    "@hapi/content": "^6.0.0",
    "cookie": "^0.6.0",
    "disposable-email-domains-js": "^1.5.0",
    "forwarded": "^0.2.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "psl": "^1.9.0",
    "zod": "^3.23.8",
    "@atproto-labs/fetch": "0.2.2",
    "@atproto-labs/fetch-node": "0.1.8",
    "@atproto-labs/pipe": "0.1.0",
    "@atproto-labs/simple-store": "0.1.2",
    "@atproto-labs/simple-store-memory": "0.1.2",
    "@atproto/common": "^0.4.10",
    "@atproto/jwk": "0.1.4",
    "@atproto/jwk-jose": "0.1.5",
    "@atproto/oauth-types": "0.2.4",
    "@atproto/oauth-provider-api": "0.0.1",
    "@atproto/oauth-provider-ui": "0.0.2",
    "@atproto/syntax": "0.4.0"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/forwarded": "0.1.3",
    "@types/psl": "1.1.3",
    "@types/send": "^0.17.4"
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.backend.json"
  }
}