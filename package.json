{
  "name": "cozycoder",
  "version": "0.1.0",
  "description": "Your cozy space for coding with AI.",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/styles.css -o ./public/styles.css",
    "watch:css": "tailwindcss -i ./assets/styles.css -o ./public/styles.css --watch",
    "copy:js": "mkdir -p public && cp node_modules/htmx.org/dist/htmx.min.js public/",
    "build": "npm run copy:js && npm run build:css",
    "dev": "npm run copy:js && npm run watch:css"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.13",
    "htmx.org": "^1.9.12",
    "tailwindcss": "^4.0.13"
  }
}
